  r.success ? toast("Compteur mis à " + count + " ✅", "success") : toast(r.error || "Erreur", "error");
}

async function deletePanel() {
  const id   = document.getElementById("ticket-panel-select")?.value;
  const name = document.getElementById("ticket-panel-select")?.selectedOptions[0]?.text;
  if (!id) { toast("Aucun panel sélectionné", "error"); return; }
  if (!confirm("Supprimer le panel \"" + name + "\" ? Cette action est irréversible.")) return;
  const r = await apiSupprimer("/ticket-panels/" + id).catch(() => ({ success: false }));
  if (r.success) {
    toast("Panel supprimé", "success");
    const bar = document.getElementById("ticket-action-bar");
    const detail = document.getElementById("ticket-panel-detail");
    const noPanel = document.getElementById("ticket-no-panel");
    if (bar) bar.style.display = "none";
    if (detail) detail.style.display = "none";
    if (noPanel) noPanel.style.display = "block";
    await loadTicketPanels();
  } else toast(r.error || "Erreur", "error");
}

</script>
</body>
</html>
