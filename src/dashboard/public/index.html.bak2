<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Orbis Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #07050f; --bg2: #0e0a1a; --bg3: #131020; --bg4: #1a1430;
  --border: rgba(124,58,237,0.15); --border-h: rgba(124,58,237,0.4);
  --purple: #7c3aed; --purple-l: #a78bfa; --purple-dim: rgba(124,58,237,0.08);
  --text: #ede9fe; --muted: #7c6fa0; --dim: #4a4060;
  --green: #10b981; --red: #ef4444; --yellow: #f59e0b; --blue: #3b82f6;
  --r: 10px; --sidebar: 230px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;display:flex;min-height:100vh;overflow-x:hidden;}

/* ── Sidebar ── */
.sidebar{width:var(--sidebar);min-height:100vh;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;left:0;top:0;bottom:0;z-index:100;overflow-y:auto;}
.sidebar::-webkit-scrollbar{width:3px;}.sidebar::-webkit-scrollbar-thumb{background:var(--border);}
.sb-logo{padding:20px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);}
.sb-logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--purple),var(--purple-l));border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:#fff;flex-shrink:0;}
.sb-logo-text{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;}
.sb-server{margin:12px 10px;padding:10px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);display:flex;align-items:center;gap:9px;}
.sb-server-icon{width:26px;height:26px;border-radius:7px;overflow:hidden;flex-shrink:0;background:var(--purple);}
.sb-server-icon img{width:100%;height:100%;object-fit:cover;}
.sb-server-name{font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
.sb-section{padding:16px 14px 4px;font-size:10px;font-weight:600;color:var(--dim);letter-spacing:1.2px;text-transform:uppercase;}
.sb-item{display:flex;align-items:center;gap:9px;padding:8px 14px;margin:1px 6px;border-radius:8px;cursor:pointer;color:var(--muted);font-size:13px;font-weight:500;transition:all .15s;position:relative;border:1px solid transparent;}
.sb-item:hover{background:var(--purple-dim);color:var(--text);}
.sb-item.active{background:var(--purple-dim);color:var(--purple-l);border-color:var(--border);}
.sb-item.active::before{content:'';position:absolute;left:-6px;top:50%;transform:translateY(-50%);width:3px;height:14px;background:var(--purple);border-radius:2px;}
.sb-icon{font-size:15px;width:16px;text-align:center;flex-shrink:0;}
.sb-badge{margin-left:auto;background:var(--purple);color:#fff;font-size:10px;padding:1px 6px;border-radius:8px;font-weight:600;}
.sb-footer{margin-top:auto;padding:12px 10px;border-top:1px solid var(--border);}
.sb-user{display:flex;align-items:center;gap:9px;}
.sb-user-av{width:30px;height:30px;border-radius:50%;overflow:hidden;flex-shrink:0;}
.sb-user-av img{width:100%;height:100%;object-fit:cover;}
.sb-user-info{flex:1;overflow:hidden;}
.sb-user-name{font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-user-role{font-size:10px;color:var(--muted);}

/* ── Main ── */
.main{margin-left:var(--sidebar);flex:1;display:flex;flex-direction:column;min-height:100vh;}
.topbar{padding:14px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--bg2);position:sticky;top:0;z-index:50;}
.page-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;}
.page-sub{font-size:11px;color:var(--muted);margin-top:2px;}
.topbar-actions{display:flex;gap:8px;align-items:center;}
.content{padding:24px;flex:1;}
.page{display:none;animation:fadeIn .2s ease;}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}

/* ── Components ── */
.btn{padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--purple);color:#fff;}.btn-primary:hover{background:#6d28d9;}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--border);}.btn-ghost:hover{border-color:var(--border-h);color:var(--text);}
.btn-danger{background:rgba(239,68,68,0.1);color:var(--red);border:1px solid rgba(239,68,68,0.2);}.btn-danger:hover{background:rgba(239,68,68,0.2);}
.btn-success{background:rgba(16,185,129,0.1);color:var(--green);border:1px solid rgba(16,185,129,0.2);}
.btn-sm{padding:4px 10px;font-size:11px;border-radius:6px;}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:18px;transition:border-color .2s;}
.card:hover{border-color:rgba(124,58,237,0.25);}
.card-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.card-title .ct-sub{color:var(--muted);font-size:11px;font-family:'DM Sans',sans-serif;font-weight:400;margin-left:auto;}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:14px;}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:14px;}
.mb{margin-bottom:14px;}

/* ── Stat cards ── */
.stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:18px;position:relative;overflow:hidden;transition:border-color .2s;}
.stat-card:hover{border-color:var(--border-h);}
.stat-card::after{content:'';position:absolute;top:0;right:0;width:50px;height:50px;background:var(--purple-dim);border-radius:0 var(--r) 0 50px;}
.stat-icon{font-size:18px;margin-bottom:10px;}
.stat-val{font-family:'Syne',sans-serif;font-size:26px;font-weight:700;}
.stat-label{font-size:11px;color:var(--muted);margin-top:3px;}
.stat-change{font-size:10px;margin-top:6px;color:var(--dim);}

/* ── Form ── */
.form-group{margin-bottom:14px;}
.form-label{font-size:11px;color:var(--muted);margin-bottom:5px;display:block;font-weight:500;letter-spacing:.3px;}
.input{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:8px 12px;border-radius:8px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s;width:100%;}
.input:focus{border-color:var(--purple);}
.input::placeholder{color:var(--dim);}
select.input{cursor:pointer;}
textarea.input{resize:vertical;min-height:72px;line-height:1.5;}

/* ── Toggle ── */
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);}
.toggle-row:last-of-type{border-bottom:none;}
.toggle-label{font-size:13px;font-weight:500;}
.toggle-sub{font-size:11px;color:var(--muted);margin-top:2px;}
.toggle{position:relative;width:38px;height:20px;flex-shrink:0;}
.toggle input{opacity:0;width:0;height:0;}
.toggle-slider{position:absolute;cursor:pointer;inset:0;background:var(--bg3);border:1px solid var(--border);border-radius:20px;transition:.2s;}
.toggle-slider:before{content:'';position:absolute;width:14px;height:14px;left:2px;bottom:2px;background:var(--dim);border-radius:50%;transition:.2s;}
.toggle input:checked+.toggle-slider{background:var(--purple);border-color:var(--purple);}
.toggle input:checked+.toggle-slider:before{transform:translateX(18px);background:#fff;}

/* ── Table ── */
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;}
th{text-align:left;padding:8px 12px;font-size:10px;color:var(--dim);font-weight:600;letter-spacing:.5px;text-transform:uppercase;border-bottom:1px solid var(--border);}
td{padding:10px 12px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:rgba(124,58,237,0.04);}
.member-cell{display:flex;align-items:center;gap:9px;}
.member-av{width:26px;height:26px;border-radius:50%;overflow:hidden;flex-shrink:0;background:var(--purple);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;}
.member-av img{width:100%;height:100%;object-fit:cover;}

/* ── Badges ── */
.badge{padding:2px 8px;border-radius:8px;font-size:11px;font-weight:500;display:inline-flex;align-items:center;gap:4px;}
.badge-admin{background:rgba(239,68,68,0.1);color:#f87171;border:1px solid rgba(239,68,68,0.15);}
.badge-mod{background:rgba(245,158,11,0.1);color:#fbbf24;border:1px solid rgba(245,158,11,0.15);}
.badge-member{background:var(--purple-dim);color:var(--purple-l);border:1px solid var(--border);}
.badge-green{background:rgba(16,185,129,0.1);color:var(--green);border:1px solid rgba(16,185,129,0.15);}
.badge-red{background:rgba(239,68,68,0.1);color:var(--red);border:1px solid rgba(239,68,68,0.15);}
.badge-yellow{background:rgba(245,158,11,0.1);color:var(--yellow);border:1px solid rgba(245,158,11,0.15);}
.badge-blue{background:rgba(59,130,246,0.1);color:var(--blue);border:1px solid rgba(59,130,246,0.15);}
.role-pill{padding:2px 8px;border-radius:6px;font-size:10px;font-weight:600;display:inline-block;margin:1px;}

/* ── Status dot ── */
.dot{width:6px;height:6px;border-radius:50%;display:inline-block;margin-right:5px;flex-shrink:0;}
.dot-online{background:var(--green);}
.dot-idle{background:var(--yellow);}
.dot-dnd{background:var(--red);}
.dot-offline{background:var(--dim);}

/* ── Search bar ── */
.search-bar{display:flex;gap:8px;margin-bottom:14px;}

/* ── Activity list ── */
.activity-item{display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--bg3);border-radius:8px;margin-bottom:6px;border:1px solid transparent;transition:border-color .15s;}
.activity-item:hover{border-color:var(--border);}
.activity-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.activity-text{flex:1;font-size:13px;line-height:1.4;}
.activity-time{font-size:10px;color:var(--dim);white-space:nowrap;}

/* ── Toast ── */
.toast{position:fixed;bottom:20px;right:20px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:12px 16px;display:flex;align-items:center;gap:10px;font-size:13px;transform:translateY(80px);opacity:0;transition:all .25s;z-index:9999;max-width:320px;box-shadow:0 8px 32px rgba(0,0,0,0.4);}
.toast.show{transform:translateY(0);opacity:1;}
.toast.success{border-color:rgba(16,185,129,0.4);}
.toast.error{border-color:rgba(239,68,68,0.4);}

/* ── Modal ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;backdrop-filter:blur(4px);}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:24px;width:440px;max-width:90vw;transform:scale(0.95);transition:transform .2s;}
.modal-overlay.open .modal{transform:scale(1);}
.modal-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;}
.modal-close{background:none;border:none;color:var(--muted);cursor:pointer;font-size:18px;padding:4px;}
.modal-close:hover{color:var(--text);}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:20px;}

/* ── Loading ── */
.loading{display:flex;align-items:center;justify-content:center;padding:48px;color:var(--muted);gap:10px;}
.spinner{width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--purple);border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── Empty state ── */
.empty{text-align:center;padding:48px 24px;color:var(--muted);}
.empty-icon{font-size:36px;margin-bottom:12px;}
.empty-text{font-size:13px;}

/* ── Bar chart ── */
.bar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.bar-lbl{width:80px;font-size:11px;color:var(--muted);text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.bar-track{flex:1;height:7px;background:var(--bg3);border-radius:4px;overflow:hidden;}
.bar-fill{height:100%;background:linear-gradient(90deg,var(--purple),var(--purple-l));border-radius:4px;transition:width .5s ease;}
.bar-val{width:28px;font-size:11px;color:var(--muted);text-align:right;}

/* ── Scrollbar ── */
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
::-webkit-scrollbar-thumb:hover{background:var(--border-h);}
</style>
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar">
  <div class="sb-logo">
    <div class="sb-logo-icon" style="background:none;padding:0;overflow:hidden;"><img src="https://i.ibb.co/xtkD3j28/image-2026-05-24-201343936.png" style="width:100%;height:100%;object-fit:cover;border-radius:9px;"></div>
    <div class="sb-logo-text">Orbis</div>
  </div>
  <div class="sb-server">
    <div class="sb-server-icon"><img id="sbGuildIcon" src="" alt=""></div>
    <div class="sb-server-name" id="sbGuildName">Chargement...</div>
  </div>

  <div class="sb-section">Général</div>
  <div class="sb-item active" data-page="overview"><span class="sb-icon">📊</span>Vue d'ensemble</div>
  <div class="sb-item" data-page="members"><span class="sb-icon">👥</span>Membres<span class="sb-badge" id="badgeMembers">—</span></div>
  <div class="sb-item" data-page="bans"><span class="sb-icon">🚫</span>Bannis</div>

  <div class="sb-section">Configuration</div>
  <div class="sb-item" data-page="settings"><span class="sb-icon">⚙️</span>Paramètres</div>
  <div class="sb-item" data-page="moderation"><span class="sb-icon">🛡️</span>Modération</div>
  <div class="sb-item" data-page="automod"><span class="sb-icon">🤖</span>AutoMod</div>
  <div class="sb-item" data-page="tickets"><span class="sb-icon">🎫</span>Tickets<span class="sb-badge" id="badgeTickets">—</span></div>
  <div class="sb-item" data-page="roles"><span class="sb-icon">🎭</span>Rôles</div>
  <div class="sb-item" data-page="autoroles"><span class="sb-icon">🔄</span>Autoroles</div>
  <div class="sb-item" data-page="welcome"><span class="sb-icon">👋</span>Bienvenue</div>
  <div class="sb-item" data-page="logs"><span class="sb-icon">📋</span>Logs</div>
  <div class="sb-item" data-page="commands"><span class="sb-icon">💬</span>Commandes</div>

  <div class="sb-section">Modules</div>
  <div class="sb-item" data-page="economy"><span class="sb-icon">💰</span>Économie</div>
  <div class="sb-item" data-page="levels"><span class="sb-icon">📈</span>Niveaux</div>
  <div class="sb-item" data-page="shop"><span class="sb-icon">🛍️</span>Boutique</div>
  <div class="sb-item" data-page="broadcast"><span class="sb-icon">📢</span>Broadcast</div>

  <div class="sb-footer">
    <div class="sb-user">
      <div class="sb-user-av"><img id="sbUserAv" src="" alt=""></div>
      <div class="sb-user-info">
        <div class="sb-user-name" id="sbUserName">—</div>
        <div class="sb-user-role">Administrateur</div>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="location.href='/auth/logout'" title="Déconnexion">⏻</button>
    </div>
  </div>
</aside>

<!-- Main -->
<main class="main">
  <div class="topbar">
    <div>
      <div class="page-title" id="pageTitle">Vue d'ensemble</div>
      <div class="page-sub" id="pageSub">Chargement...</div>
    </div>
    <div class="topbar-actions">
      <button class="btn btn-ghost" onclick="refreshPage()">↻ Actualiser</button>
    </div>
  </div>

  <div class="content">

    <!-- ════ OVERVIEW ════ -->
    <div class="page active" id="page-overview">
      <div class="grid-4 mb">
        <div class="stat-card"><div class="stat-icon">👥</div><div class="stat-val" id="st-members">—</div><div class="stat-label">Membres total</div></div>
        <div class="stat-card"><div class="stat-icon">🟢</div><div class="stat-val" id="st-online">—</div><div class="stat-label">En ligne</div></div>
        <div class="stat-card"><div class="stat-icon">#</div><div class="stat-val" id="st-channels">—</div><div class="stat-label">Salons</div></div>
        <div class="stat-card"><div class="stat-icon">🎭</div><div class="stat-val" id="st-roles">—</div><div class="stat-label">Rôles</div></div>
      </div>
      <div class="grid-2">
        <div class="card">
          <div class="card-title">🏆 Top membres (XP)</div>
          <div id="overview-levels"><div class="loading"><div class="spinner"></div>Chargement...</div></div>
        </div>
        <div class="card">
          <div class="card-title">💰 Top économie</div>
          <div id="overview-economy"><div class="loading"><div class="spinner"></div>Chargement...</div></div>
        </div>
      </div>
      <div class="card">
        <div class="card-title">🎫 Tickets récents <span class="ct-sub" id="tickets-count-label"></span></div>
        <div id="overview-tickets"><div class="loading"><div class="spinner"></div>Chargement...</div></div>
      </div>
    </div>

    <!-- ════ MEMBERS ════ -->
    <div class="page" id="page-members">
      <div class="search-bar">
        <input class="input" type="text" placeholder="🔍 Rechercher..." id="memberSearch" oninput="filterMembers()">
        <select class="input" style="width:160px" id="memberRoleFilter" onchange="filterMembers()"><option value="">Tous les rôles</option></select>
        <select class="input" style="width:140px" id="memberStatusFilter" onchange="filterMembers()">
          <option value="">Tous les statuts</option>
          <option value="online">En ligne</option>
          <option value="offline">Hors ligne</option>
        </select>
      </div>
      <div class="card">
        <div class="table-wrap">
          <table>
            <thead><tr><th>Membre</th><th>Rôles</th><th>Statut</th><th>Rejoint le</th><th>Niv.</th><th>Solde</th><th>Actions</th></tr></thead>
            <tbody id="members-tbody"><tr><td colspan="7"><div class="loading"><div class="spinner"></div>Chargement...</div></td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════ BANS ════ -->
    <div class="page" id="page-bans">
      <div class="card">
        <div class="card-title">🚫 Membres bannis</div>
        <div id="bans-list"><div class="loading"><div class="spinner"></div>Chargement...</div></div>
      </div>
    </div>

    <!-- ════ SETTINGS ════ -->
    <div class="page" id="page-settings">
      <div class="grid-2">
        <div class="card">
          <div class="card-title">⚙️ Général</div>
          <div class="form-group"><label class="form-label">Préfixe de commande</label><input class="input" id="s-prefix" type="text" maxlength="5"></div>
          <div class="form-group"><label class="form-label">Salon des logs</label><select class="input" id="s-log_channel"></select></div>
          <div class="form-group"><label class="form-label">Salon des suggestions</label><select class="input" id="s-suggestion_channel"></select></div>
          <div class="form-group"><label class="form-label">Salon des reports</label><select class="input" id="s-report_channel"></select></div>
        </div>
        <div class="card">
          <div class="card-title">🎭 Modules</div>
          <div class="toggle-row"><div><div class="toggle-label">Système de niveaux</div></div><label class="toggle"><input type="checkbox" id="s-levels_enabled"><span class="toggle-slider"></span></label></div>
          <div class="toggle-row"><div><div class="toggle-label">Économie</div></div><label class="toggle"><input type="checkbox" id="s-economy_enabled"><span class="toggle-slider"></span></label></div>
          <div class="form-group" style="margin-top:14px"><label class="form-label">Rôle auto (arrivée)</label><select class="input" id="s-auto_role"></select></div>
        </div>
      </div>
      <button class="btn btn-primary" onclick="saveSettings()">💾 Sauvegarder</button>
    </div>

    <!-- ════ MODERATION ════ -->
    <div class="page" id="page-moderation">
      <div class="card mb">
        <div class="card-title">⚖️ Derniers avertissements</div>
        <div class="search-bar"><input class="input" type="text" placeholder="🔍 Filtrer..." id="warnSearch" oninput="filterWarnings()"><button class="btn btn-primary" onclick="openWarnModal()">+ Ajouter un warn</button></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Utilisateur</th><th>Raison</th><th>Modérateur</th><th>Date</th><th>Actions</th></tr></thead>
            <tbody id="warns-tbody"><tr><td colspan="5"><div class="loading"><div class="spinner"></div>Chargement...</div></td></tr></tbody>
          </table>
        </div>
      </div>
      <div class="card">
        <div class="card-title">🔨 Dernières sanctions</div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Type</th><th>Utilisateur</th><th>Raison</th><th>Date</th></tr></thead>
            <tbody id="sanctions-tbody"><tr><td colspan="4"><div class="loading"><div class="spinner"></div>Chargement...</div></td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════ AUTOMOD ════ -->
    <div class="page" id="page-automod">
      <div class="grid-2">
        <div class="card">
          <div class="card-title">🤖 Protection automatique</div>
          <div class="toggle-row"><div><div class="toggle-label">AutoMod activé</div><div class="toggle-sub">Active toutes les protections</div></div><label class="toggle"><input type="checkbox" id="s-automod_enabled" onchange="autoSave('automod_enabled',this.checked?1:0)"><span class="toggle-slider"></span></label></div>
          <div class="toggle-row"><div><div class="toggle-label">Anti-spam</div><div class="toggle-sub">Limite les messages répétitifs</div></div><label class="toggle"><input type="checkbox" id="s-automod_anti_spam" onchange="autoSave('automod_anti_spam',this.checked?1:0)"><span class="toggle-slider"></span></label></div>
          <div class="toggle-row"><div><div class="toggle-label">Anti-liens</div><div class="toggle-sub">Supprime les liens non autorisés</div></div><label class="toggle"><input type="checkbox" id="s-automod_anti_link" onchange="autoSave('automod_anti_link',this.checked?1:0)"><span class="toggle-slider"></span></label></div>
        </div>
        <div class="card">
          <div class="card-title">🚫 Mots bannis</div>
          <div class="form-group"><label class="form-label">Mots interdits (un par ligne)</label><textarea class="input" id="badwords-input" rows="6" placeholder="spam&#10;insulte&#10;..."></textarea></div>
          <button class="btn btn-primary" onclick="saveBadwords()">💾 Sauvegarder</button>
        </div>
      </div>
    </div>

    <!-- ════ TICKETS ════ -->
    <div class="page" id="page-tickets">

      <!-- Top bar style Ticket Tool -->
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;background:var(--bg2);padding:10px 14px;border-radius:8px;border:1px solid var(--border)">
        <select class="input" id="ticket-panel-select" onchange="loadPanelDetails()" style="max-width:280px;background:var(--bg3)">
          <option value="">— Sélectionner un panel —</option>
        </select>
        <button class="btn btn-primary" onclick="openCreatePanelModal()" style="background:#7c3aed;border:none;padding:7px 16px;border-radius:6px;font-weight:600">+ Nouveau Panel</button>
      </div>

      <!-- Boutons action style Ticket Tool -->
      <div id="ticket-action-bar" style="display:none;justify-content:center;gap:8px;margin-bottom:18px;flex-wrap:wrap">
        <button onclick="clonePanel()"  style="padding:7px 18px;border-radius:6px;border:1px solid var(--border);background:var(--bg3);color:var(--text);cursor:pointer;font-size:13px">Cloner</button>
        <button onclick="openRenommerPanelModal()" style="padding:7px 18px;border-radius:6px;border:none;background:#22c55e;color:#fff;cursor:pointer;font-size:13px;font-weight:600">Renommer</button>
        <button onclick="sendPanel()"   style="padding:7px 18px;border-radius:6px;border:1px solid var(--border);background:var(--bg3);color:var(--text);cursor:pointer;font-size:13px">Envoyer</button>
        <button onclick="setCount()"    style="padding:7px 18px;border-radius:6px;border:1px solid var(--border);background:var(--bg3);color:var(--text);cursor:pointer;font-size:13px">Compteur</button>
        <button onclick="updatePanel()" style="padding:7px 18px;border-radius:6px;border:none;background:#3b82f6;color:#fff;cursor:pointer;font-size:13px;font-weight:600">Mettre à jour</button>
        <button onclick="deletePanel()" style="padding:7px 18px;border-radius:6px;border:none;background:#ef4444;color:#fff;cursor:pointer;font-size:13px;font-weight:600">Supprimer</button>
      </div>

      <div id="ticket-panel-detail" style="display:none">

        <!-- General Ticket Options -->
        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:18px;margin-bottom:18px">
          <div style="font-size:13px;font-weight:600;color:var(--muted);margin-bottom:14px;text-transform:uppercase;letter-spacing:.05em">Options Générales des Tickets</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
            <div onclick="openSection('general')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Général</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Équipe support et options générales</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('category')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Catégorie</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options de catégorie pour tickets ouverts/fermés.</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('ticket')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Ticket</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options générales du ticket</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('moderator')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Modérateur</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options des messages modérateur</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('permissions')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Permissions</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options de permissions</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('buttons')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Boutons</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Liste rapide de tous les boutons</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('messages')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Messages</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Liste rapide de tous les messages</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('escalate')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Escalader</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options d'escalade</div></div><span style="color:var(--muted)">›</span></div>
          </div>
        </div>

        <!-- Panel Settings -->
        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:18px;margin-bottom:18px">
          <div style="font-size:13px;font-weight:600;color:var(--muted);margin-bottom:14px;text-transform:uppercase;letter-spacing:.05em">Paramètres du Panel</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
            <div onclick="openSection('panel')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Panel</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options du message pour créer des tickets</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('command_style')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Style Commande</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Créer des tickets via commandes.</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('dropdown_style')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Style Menu Déroulant</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Créer des tickets via menu déroulant.</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('thread_style')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Style Thread</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Tickets en threads plutôt qu'en salons.</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('forms')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Formulaires</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options des formulaires</div></div><span style="color:var(--muted)">›</span></div>
          </div>
        </div>

        <!-- Advanced Settings -->
        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:18px;margin-bottom:18px">
          <div style="font-size:13px;font-weight:600;color:var(--muted);margin-bottom:14px;text-transform:uppercase;letter-spacing:.05em">Paramètres Avancés</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
            <div onclick="openSection('transcript')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Transcript</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options pour sauvegarder vos transcripts</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('logging')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Logs</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options pour les logs du serveur</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('automation')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Automatisation</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options d'automatisation</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('limits')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Limites</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Limites et planification</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('claiming')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Réclamation</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Options de réclamation</div></div><span style="color:var(--muted)">›</span></div>
            <div onclick="openSection('integrations')" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color .2s" onmouseover="this.style.borderColor='#7c3aed'" onmouseout="this.style.borderColor='var(--border)'"><div><div style="font-weight:600;font-size:14px">Intégrations</div><div style="font-size:11px;color:var(--muted);margin-top:3px">Intégrations de bots externes</div></div><span style="color:var(--muted)">›</span></div>
          </div>
        </div>

        <!-- Configs Fréquemment Utilisées -->
        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:18px;margin-bottom:18px">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;cursor:pointer" onclick="toggleFrequent()">
            <span id="freq-arrow" style="font-size:12px;color:var(--muted)">▲</span>
            <span style="font-weight:600;font-size:14px">Configs Fréquemment Utilisées</span>
          </div>
          <div id="freq-body">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px">
              <div>
                <div style="font-size:12px;color:var(--muted);margin-bottom:6px;display:flex;align-items:center;gap:6px">Rôles de l'Équipe Support <span style="background:var(--bg3);border-radius:50%;width:16px;height:16px;display:inline-flex;align-items:center;justify-content:center;font-size:10px;cursor:help" title="Rôles pouvant gérer les tickets">?</span></div>
                <select class="input" id="p-support_role_id" style="width:100%"></select>
              </div>
              <div>
                <div style="font-size:12px;color:var(--muted);margin-bottom:6px;display:flex;align-items:center;gap:6px">Catégorie Créée/Ouverte <span style="background:var(--bg3);border-radius:50%;width:16px;height:16px;display:inline-flex;align-items:center;justify-content:center;font-size:10px;cursor:help" title="Catégorie Discord où les tickets sont créés">?</span></div>
                <select class="input" id="p-default_category_id" style="width:100%"></select>
              </div>
              <div>
                <div style="font-size:12px;color:var(--muted);margin-bottom:6px;display:flex;align-items:center;gap:6px">Message du Panel <span style="background:var(--bg3);border-radius:50%;width:16px;height:16px;display:inline-flex;align-items:center;justify-content:center;font-size:10px;cursor:help" title="Le message affiché dans le panel">?</span></div>
                <button class="btn btn-primary" onclick="openSection('panel')" style="width:100%;background:#22c55e;border:none;padding:9px;border-radius:6px;font-weight:600;cursor:pointer">Edit Message du Panel</button>
              </div>
              <div>
                <div style="font-size:12px;color:var(--muted);margin-bottom:6px;display:flex;align-items:center;gap:6px">Message du Ticket <span style="background:var(--bg3);border-radius:50%;width:16px;height:16px;display:inline-flex;align-items:center;justify-content:center;font-size:10px;cursor:help" title="Le message affiché à l'ouverture du ticket">?</span></div>
                <button class="btn btn-primary" onclick="openSection('ticket')" style="width:100%;background:#22c55e;border:none;padding:9px;border-radius:6px;font-weight:600;cursor:pointer">Edit Message du Ticket</button>
              </div>
            </div>
            <div style="margin-top:14px;text-align:right">
              <button onclick="saveFrequentConfigs()" style="padding:8px 20px;background:#7c3aed;color:#fff;border:none;border-radius:6px;font-weight:600;cursor:pointer">💾 Sauvegarder</button>
            </div>
          </div>
        </div>

        <!-- Stats -->
        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:18px">
          <div style="font-weight:600;margin-bottom:12px">📊 Statistiques</div>
          <div id="ticket-stats"></div>
        </div>

      </div>

      <div id="ticket-no-panel">
        <div class="empty"><div class="empty-icon">🎫</div><div class="empty-text">Aucun panel sélectionné — créez un nouveau panel pour commencer</div></div>
      </div>

    </div>
    <!-- ════ ROLES ════ -->
    <div class="page" id="page-roles">
      <div class="search-bar">
        <input class="input" type="text" placeholder="🔍 Filtrer les rôles..." id="roleSearch" oninput="filterRoles()">
        <button class="btn btn-primary" onclick="openCreateRoleModal()">+ Créer un rôle</button>
      </div>
      <div class="card">
        <div class="table-wrap">
          <table>
            <thead><tr><th>Rôle</th><th>Couleur</th><th>Membres</th><th>Position</th><th>Actions</th></tr></thead>
            <tbody id="roles-tbody"><tr><td colspan="5"><div class="loading"><div class="spinner"></div>Chargement...</div></td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════ AUTOROLES ════ -->
    <div class="page" id="page-autoroles">
      <div class="card mb">
        <div class="card-title">🔄 Rôles automatiques</div>
        <p style="color:var(--muted);font-size:12px;margin-bottom:14px">Ces rôles sont attribués automatiquement à l'arrivée d'un nouveau membre.</p>
        <div id="autoroles-list"><div class="loading"><div class="spinner"></div>Chargement...</div></div>
        <div style="display:flex;gap:8px;margin-top:14px;align-items:center;">
          <select class="input" id="autorole-role-select" style="flex:1"></select>
          <select class="input" style="width:120px" id="autorole-type-select">
            <option value="all">Tous</option>
            <option value="human">Humains</option>
            <option value="bot">Bots</option>
          </select>
          <button class="btn btn-primary" onclick="addAutorole()">+ Ajouter</button>
        </div>
      </div>
    </div>

    <!-- ════ WELCOME ════ -->
    <div class="page" id="page-welcome">
      <div class="grid-2">
        <div class="card">
          <div class="card-title">👋 Bienvenue</div>
          <div class="form-group"><label class="form-label">Salon</label><select class="input" id="s-welcome_channel"></select></div>
          <div class="form-group"><label class="form-label">Message <span style="color:var(--dim)">{user} {server} {count}</span></label><textarea class="input" id="s-welcome_message" rows="4"></textarea></div>
          <button class="btn btn-primary" onclick="saveSettings()">💾 Sauvegarder</button>
        </div>
        <div class="card">
          <div class="card-title">👋 Au revoir</div>
          <div class="form-group"><label class="form-label">Salon</label><select class="input" id="s-leave_channel"></select></div>
          <div class="form-group"><label class="form-label">Message <span style="color:var(--dim)">{user} {count}</span></label><textarea class="input" id="s-leave_message" rows="4"></textarea></div>
          <button class="btn btn-primary" onclick="saveSettings()">💾 Sauvegarder</button>
        </div>
      </div>
    </div>

    <!-- ════ LOGS ════ -->
    <div class="page" id="page-logs">
      <div class="card">
        <div class="card-title">📋 Salon de logs</div>
        <div class="form-group"><label class="form-label">Salon de logs principal</label><select class="input" id="logs-log_channel"></select></div>
        <button class="btn btn-primary" onclick="saveLogChannel()">💾 Sauvegarder</button>
      </div>
    </div>

    <!-- ════ COMMANDS ════ -->
    <div class="page" id="page-commands">
      <div class="card mb">
        <div class="card-title">💬 Commandes personnalisées</div>
        <div class="search-bar">
          <input class="input" type="text" placeholder="🔍 Filtrer..." id="cmdSearch" oninput="filterCommands()">
          <button class="btn btn-primary" onclick="openCreateCmdModal()">+ Créer</button>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Nom</th><th>Réponse</th><th>Créé par</th><th>Actions</th></tr></thead>
            <tbody id="commands-tbody"><tr><td colspan="4"><div class="loading"><div class="spinner"></div>Chargement...</div></td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════ ECONOMY ════ -->
    <div class="page" id="page-economy">
      <div class="card mb">
        <div class="card-title">💰 Classement économie <span class="ct-sub">Top 20</span></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>#</th><th>Utilisateur</th><th>Portefeuille</th><th>Banque</th><th>Total</th></tr></thead>
            <tbody id="economy-tbody"><tr><td colspan="5"><div class="loading"><div class="spinner"></div>Chargement...</div></td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════ LEVELS ════ -->
    <div class="page" id="page-levels">
      <div class="grid-2 mb">
        <div class="card">
          <div class="card-title">⚙️ Configuration XP</div>
          <div class="form-group"><label class="form-label">Salon d'annonce de niveau</label><select class="input" id="s-levels_channel"></select></div>
          <div class="form-group"><label class="form-label">Message de level up <span style="color:var(--dim)">{user} {level}</span></label><input class="input" id="s-levels_message" type="text"></div>
          <button class="btn btn-primary" onclick="saveSettings()">💾 Sauvegarder</button>
        </div>
        <div class="card">
          <div class="card-title">📊 Classement XP <span class="ct-sub">Top 20</span></div>
          <div id="levels-bars"><div class="loading"><div class="spinner"></div>Chargement...</div></div>
        </div>
      </div>
      <div class="card">
        <div class="card-title">🏆 Tableau complet</div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>#</th><th>Utilisateur</th><th>Niveau</th><th>XP total</th><th>Messages</th></tr></thead>
            <tbody id="levels-tbody"><tr><td colspan="5"><div class="loading"><div class="spinner"></div>Chargement...</div></td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════ SHOP ════ -->
    <div class="page" id="page-shop">
      <div class="search-bar">
        <input class="input" type="text" placeholder="🔍 Filtrer..." id="shopSearch" oninput="filterShop()">
        <button class="btn btn-primary" onclick="openAddShopModal()">+ Ajouter un article</button>
      </div>
      <div class="card">
        <div class="table-wrap">
          <table>
            <thead><tr><th>Article</th><th>Description</th><th>Prix</th><th>Rôle</th><th>Actions</th></tr></thead>
            <tbody id="shop-tbody"><tr><td colspan="5"><div class="loading"><div class="spinner"></div>Chargement...</div></td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════ BROADCAST ════ -->
    <div class="page" id="page-broadcast">
      <div class="card" style="max-width:600px">
        <div class="card-title">📢 Envoyer un message</div>
        <div class="form-group"><label class="form-label">Salon</label><select class="input" id="broadcast-channel"></select></div>
        <div class="form-group"><label class="form-label">Type</label><select class="input" id="broadcast-type"><option value="text">Message simple</option><option value="embed">Embed</option></select></div>
        <div id="broadcast-embed-fields" style="display:none"><div class="form-group"><label class="form-label">Titre de l'embed</label><input class="input" id="broadcast-title" type="text"></div></div>
        <div class="form-group"><label class="form-label">Message</label><textarea class="input" id="broadcast-content" rows="5" placeholder="Tape ton message ici..."></textarea></div>
        <button class="btn btn-primary" onclick="sendBroadcast()">📤 Envoyer</button>
      </div>
    </div>

  </div><!-- /content -->
</main>

<!-- Toast -->
<div class="toast" id="toast"><span id="toast-icon"></span><span id="toast-msg"></span></div>

<!-- Modal: Action membre -->
<div class="modal-overlay" id="modal-member">
  <div class="modal">
    <div class="modal-title"><span id="modal-member-title">Action</span><button class="modal-close" onclick="closeModal('modal-member')">✕</button></div>
    <div class="form-group"><label class="form-label">Raison</label><input class="input" id="modal-member-reason" type="text" placeholder="Raison..."></div>
    <div id="modal-member-extra"></div>
    <div class="modal-actions"><button class="btn btn-ghost" onclick="closeModal('modal-member')">Annuler</button><button class="btn btn-danger" id="modal-member-confirm">Confirmer</button></div>
  </div>
</div>

<!-- Modal: Warn -->
<div class="modal-overlay" id="modal-warn">
  <div class="modal">
    <div class="modal-title">⚠️ Ajouter un avertissement<button class="modal-close" onclick="closeModal('modal-warn')">✕</button></div>
    <div class="form-group"><label class="form-label">ID ou nom du membre</label><select class="input" id="warn-user-select"></select></div>
    <div class="form-group"><label class="form-label">Raison</label><input class="input" id="warn-reason" type="text" placeholder="Raison de l'avertissement..."></div>
    <div class="modal-actions"><button class="btn btn-ghost" onclick="closeModal('modal-warn')">Annuler</button><button class="btn btn-primary" onclick="submitWarn()">Ajouter</button></div>
  </div>
</div>

<!-- Modal: Create role -->
<div class="modal-overlay" id="modal-role">
  <div class="modal">
    <div class="modal-title">🎭 Créer un rôle<button class="modal-close" onclick="closeModal('modal-role')">✕</button></div>
    <div class="form-group"><label class="form-label">Nom</label><input class="input" id="role-name" type="text" placeholder="Nom du rôle"></div>
    <div class="form-group"><label class="form-label">Couleur</label><input class="input" id="role-color" type="color" value="#7c3aed" style="height:38px;padding:2px 6px;cursor:pointer;"></div>
    <div class="modal-actions"><button class="btn btn-ghost" onclick="closeModal('modal-role')">Annuler</button><button class="btn btn-primary" onclick="createRole()">Créer</button></div>
  </div>
</div>

<!-- Modal: Create command -->
<div class="modal-overlay" id="modal-cmd">
  <div class="modal">
    <div class="modal-title">💬 Nouvelle commande<button class="modal-close" onclick="closeModal('modal-cmd')">✕</button></div>
    <div class="form-group"><label class="form-label">Nom (sans préfixe)</label><input class="input" id="cmd-name" type="text" placeholder="ex: règles"></div>
    <div class="form-group"><label class="form-label">Réponse</label><textarea class="input" id="cmd-response" rows="4" placeholder="Contenu de la réponse..."></textarea></div>
    <div class="modal-actions"><button class="btn btn-ghost" onclick="closeModal('modal-cmd')">Annuler</button><button class="btn btn-primary" onclick="createCmd()">Créer</button></div>
  </div>
</div>

<!-- Modal: Add shop item -->
<div class="modal-overlay" id="modal-shop">
  <div class="modal">
    <div class="modal-title">🛍️ Ajouter un article<button class="modal-close" onclick="closeModal('modal-shop')">✕</button></div>
    <div class="form-group"><label class="form-label">Nom</label><input class="input" id="shop-name" type="text"></div>
    <div class="form-group"><label class="form-label">Description</label><input class="input" id="shop-desc" type="text"></div>
    <div class="form-group"><label class="form-label">Prix (coins)</label><input class="input" id="shop-price" type="number" min="1"></div>
    <div class="form-group"><label class="form-label">Emoji</label><input class="input" id="shop-emoji" type="text" value="🛍️" maxlength="4"></div>
    <div class="form-group"><label class="form-label">Rôle attribué (optionnel)</label><select class="input" id="shop-role"><option value="">Aucun</option></select></div>
    <div class="modal-actions"><button class="btn btn-ghost" onclick="closeModal('modal-shop')">Annuler</button><button class="btn btn-primary" onclick="addShopItem()">Ajouter</button></div>
  </div>
</div>

<script>
// ══════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════
const GUILD_ID = location.pathname.split('/')[2];
let state = { guild: null, members: [], roles: [], channels: [], settings: {}, warns: [], sanctions: [], tickets: [], levels: [], economy: [], commands: [], shop: [], bans: [], autoroles: [] };
let currentPage = 'overview';

// ══════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════
async function init() {
  await Promise.all([loadGuild(), loadChannels(), loadRoles()]);
  loadPage('overview');
  setupNav();
  document.getElementById('broadcast-type').addEventListener('change', e => {
    document.getElementById('broadcast-embed-fields').style.display = e.target.value === 'embed' ? 'block' : 'none';
  });
}

function setupNav() {
  document.querySelectorAll('.sb-item').forEach(el => {
    el.addEventListener('click', () => {
      const p = el.dataset.page;
      if (p) loadPage(p);
    });
  });
}

async function loadPage(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sb-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + page)?.classList.add('active');
  document.querySelector(`.sb-item[data-page="${page}"]`)?.classList.add('active');
  currentPage = page;
  const titles = {
    overview:'Vue d\'ensemble', members:'Membres', bans:'Bannis', settings:'Paramètres',
    moderation:'Modération', automod:'AutoMod', tickets:'Tickets', roles:'Rôles',
    autoroles:'Autoroles', welcome:'Bienvenue / Au revoir', logs:'Logs',
    commands:'Commandes personnalisées', economy:'Économie', levels:'Niveaux',
    shop:'Boutique', broadcast:'Broadcast'
  };
  document.getElementById('pageTitle').textContent = titles[page] || page;
  if (state.guild) document.getElementById('pageSub').textContent = state.guild.name;
  const loaders = {
    overview: loadOverview, members: loadMembers, bans: loadBans,
    settings: loadSettingsPage, moderation: loadModeration, automod: loadAutomod,
    tickets: loadTickets, roles: loadRoles2, autoroles: loadAutoroles,
    welcome: loadWelcome, logs: loadLogsPage, commands: loadCommands,
    economy: loadEconomy, levels: loadLevels, shop: loadShop,
    broadcast: loadBroadcastChannels
  };
  if (loaders[page]) await loaders[page]();
}

function refreshPage() { loadPage(currentPage); }

// ══════════════════════════════════════════════
//  API HELPERS
// ══════════════════════════════════════════════
async function api(path, opts = {}) {
  const res = await fetch(`/api/guild/${GUILD_ID}${path}`, {
    headers: { 'Content-Type': 'application/json' },
    ...opts
  });
  return res.json();
}

async function apiPatch(path, body) { return api(path, { method: 'PATCH', body: JSON.stringify(body) }); }
async function apiPost(path, body) { return api(path, { method: 'POST', body: JSON.stringify(body) }); }
async function apiSupprimer(path) { return api(path, { method: 'DELETE' }); }

// ══════════════════════════════════════════════
//  GUILD
// ══════════════════════════════════════════════
async function loadGuild() {
  const g = await api('');
  state.guild = g;
  document.getElementById('sbGuildName').textContent = g.name;
  if (g.icon) document.getElementById('sbGuildIcon').src = g.icon;
  document.getElementById('st-members').textContent = g.memberCount;
  document.getElementById('st-online').textContent = g.onlineCount;
  document.getElementById('st-channels').textContent = g.channelCount;
  document.getElementById('st-roles').textContent = g.roleCount;
  document.getElementById('badgeMembers').textContent = g.memberCount;
  document.getElementById('pageSub').textContent = g.name;
  state.settings = g.settings || {};
}

async function loadChannels() {
  state.channels = await api('/channels');
}

async function loadRoles() {
  state.roles = await api('/roles');
}

// ══════════════════════════════════════════════
//  OVERVIEW
// ══════════════════════════════════════════════
async function loadOverview() {
  const [lvls, eco, tix] = await Promise.all([api('/levels'), api('/economy'), api('/tickets')]);
  state.levels = lvls; state.economy = eco; state.tickets = tix;

  // Levels top 5
  const lEl = document.getElementById('overview-levels');
  if (!lvls.length) { lEl.innerHTML = '<div class="empty"><div class="empty-icon">📊</div><div class="empty-text">Aucune donnée</div></div>'; }
  else {
    const max = lvls[0]?.xp || 1;
    lEl.innerHTML = lvls.slice(0,5).map((r,i) => `
      <div class="bar-row">
        <div class="bar-lbl">${['🥇','🥈','🥉','4.','5.'][i]} Lv.${r.level}</div>
        <div class="bar-track"><div class="bar-fill" style="width:${Math.round(r.xp/max*100)}%"></div></div>
        <div class="bar-val">${r.xp}</div>
      </div>`).join('');
  }

  // Economy top 5
  const eEl = document.getElementById('overview-economy');
  if (!eco.length) { eEl.innerHTML = '<div class="empty"><div class="empty-icon">💰</div><div class="empty-text">Aucune donnée</div></div>'; }
  else {
    const maxE = (eco[0]?.balance||0)+(eco[0]?.bank||0) || 1;
    eEl.innerHTML = eco.slice(0,5).map((r,i) => {
      const total = (r.balance||0)+(r.bank||0);
      return `<div class="bar-row"><div class="bar-lbl">${['🥇','🥈','🥉','4.','5.'][i]} ${total}🪙</div><div class="bar-track"><div class="bar-fill" style="width:${Math.round(total/maxE*100)}%"></div></div><div class="bar-val">${r.balance}</div></div>`;
    }).join('');
  }

  // Tickets
  const tEl = document.getElementById('overview-tickets');
  const open = tix.filter(t => t.status === 'open');
  document.getElementById('tickets-count-label').textContent = `${open.length} ouvert(s)`;
  document.getElementById('badgeTickets').textContent = open.length;
  if (!open.length) { tEl.innerHTML = '<div class="empty"><div class="empty-icon">🎫</div><div class="empty-text">Aucun ticket ouvert</div></div>'; }
  else tEl.innerHTML = open.slice(0,5).map(t => `
    <div class="activity-item">
      <div class="activity-dot" style="background:var(--green)"></div>
      <div class="activity-text">#${t.id} — ${t.subject || 'Sans sujet'}</div>
      <div class="activity-time">${fmtDate(t.created_at)}</div>
    </div>`).join('');
}

// ══════════════════════════════════════════════
//  MEMBERS
// ══════════════════════════════════════════════
async function loadMembers() {
  document.getElementById('members-tbody').innerHTML = '<tr><td colspan="7"><div class="loading"><div class="spinner"></div>Chargement...</div></td></tr>';
  state.members = await api('/members');
  // Populate role filter
  const rf = document.getElementById('memberRoleFilter');
  rf.innerHTML = '<option value="">Tous les rôles</option>';
  state.roles.forEach(r => rf.innerHTML += `<option value="${r.id}">${r.name}</option>`);
  // Populate warn modal
  const ws = document.getElementById('warn-user-select');
  ws.innerHTML = state.members.filter(m=>!m.bot).map(m=>`<option value="${m.id}">${m.displayName} (${m.username})</option>`).join('');
  renderMembers(state.members);
}

function filterMembers() {
  const q = document.getElementById('memberSearch').value.toLowerCase();
  const role = document.getElementById('memberRoleFilter').value;
  const status = document.getElementById('memberStatusFilter').value;
  const filtered = state.members.filter(m => {
    const matchQ = !q || m.username.toLowerCase().includes(q) || m.displayName.toLowerCase().includes(q);
    const matchR = !role || m.roles.some(r => r.id === role);
    const matchS = !status || m.status === status || (status === 'offline' && !m.status || m.status === 'offline');
    return matchQ && matchR && matchS;
  });
  renderMembers(filtered);
}

function renderMembers(members) {
  const tb = document.getElementById('members-tbody');
  if (!members.length) { tb.innerHTML = '<tr><td colspan="7"><div class="empty"><div class="empty-icon">👥</div><div class="empty-text">Aucun membre trouvé</div></div></td></tr>'; return; }
  tb.innerHTML = members.map(m => {
    const topRole = m.roles[0];
    const roleHtml = topRole ? `<span class="role-pill" style="background:${topRole.color}22;color:${topRole.color};border:1px solid ${topRole.color}44">${topRole.name}</span>` : '<span style="color:var(--dim)">—</span>';
    const statusClass = {'online':'dot-online','idle':'dot-idle','dnd':'dot-dnd'}[m.status] || 'dot-offline';
    const statusLabel = {'online':'En ligne','idle':'Absent','dnd':'Ne pas déranger'}[m.status] || 'Hors ligne';
    return `<tr>
      <td><div class="member-cell">
        <div class="member-av"><img src="${m.avatar}" onerror="this.parentElement.textContent='${m.username[0]?.toUpperCase()}'"></div>
        <div><div style="font-weight:500">${m.displayName}</div><div style="font-size:10px;color:var(--muted)">${m.username}${m.bot?' 🤖':''}</div></div>
      </div></td>
      <td>${roleHtml}</td>
      <td><span class="dot ${statusClass}"></span>${statusLabel}</td>
      <td style="color:var(--muted);font-size:12px">${m.joinedAt ? new Date(m.joinedAt).toLocaleDateString('fr-FR') : '—'}</td>
      <td><span class="badge badge-blue">Niv. ${m.level?.level||0}</span></td>
      <td style="color:var(--muted)">${(m.economy?.balance||0)+(m.economy?.bank||0)} 🪙</td>
      <td>
        ${m.bot ? '' : `
        <button class="btn btn-ghost btn-sm" onclick="openMemberRoles('${m.id}','${m.displayName.replace(/'/g,"\\'")}')">🎭</button>
        <button class="btn btn-ghost btn-sm" onclick="openMemberAction('${m.id}','${m.displayName.replace(/'/g,"\\'")}','timeout')">⏱️</button>
        <button class="btn btn-ghost btn-sm" onclick="openMemberAction('${m.id}','${m.displayName.replace(/'/g,"\\'")}','kick')">👢</button>
        <button class="btn btn-danger btn-sm" onclick="openMemberAction('${m.id}','${m.displayName.replace(/'/g,"\\'")}','ban')">🔨</button>`}
      </td>
    </tr>`;
  }).join('');
}

// ── Member actions modal ──
let _memberActionTarget = null;
function openMemberAction(userId, name, action) {
  _memberActionTarget = { userId, action };
  const labels = { kick:'👢 Kick', ban:'🔨 Bannir', timeout:'⏱️ Timeout' };
  document.getElementById('modal-member-title').textContent = `${labels[action]} — ${name}`;
  document.getElementById('modal-member-reason').value = '';
  const extra = document.getElementById('modal-member-extra');
  extra.innerHTML = action === 'timeout' ? `<div class="form-group"><label class="form-label">Durée</label><select class="input" id="timeout-duration"><option value="300000">5 minutes</option><option value="600000" selected>10 minutes</option><option value="3600000">1 heure</option><option value="86400000">24 heures</option><option value="604800000">7 jours</option></select></div>` : '';
  const btn = document.getElementById('modal-member-confirm');
  btn.className = `btn ${action === 'ban' ? 'btn-danger' : 'btn-primary'}`;
  btn.textContent = labels[action];
  btn.onclick = confirmMemberAction;
  openModal('modal-member');
}

async function confirmMemberAction() {
  const { userId, action } = _memberActionTarget;
  const reason = document.getElementById('modal-member-reason').value || 'Action via le dashboard';
  let body = { reason };
  if (action === 'timeout') body.duration = parseInt(document.getElementById('timeout-duration').value);
  const r = await apiPost(`/members/${userId}/${action}`, body);
  if (r.success) { toast('Action effectuée ✅', 'success'); closeModal('modal-member'); loadMembers(); }
  else toast(r.error, 'error');
}

function openMemberRoles(userId, name) {
  const member = state.members.find(m => m.id === userId);
  if (!member) return;
  const memberRoleIds = new Set(member.roles.map(r => r.id));
  const html = `<div style="max-height:300px;overflow-y:auto">` + state.roles.map(r => `
    <div class="toggle-row">
      <div><div class="toggle-label">${r.name}</div><div class="toggle-sub">${r.memberCount} membres</div></div>
      <label class="toggle"><input type="checkbox" ${memberRoleIds.has(r.id)?'checked':''} onchange="toggleMemberRole('${userId}','${r.id}',this.checked)"><span class="toggle-slider"></span></label>
    </div>`).join('') + '</div>';
  _memberActionTarget = { userId };
  document.getElementById('modal-member-title').textContent = `🎭 Rôles de ${name}`;
  document.getElementById('modal-member-reason').closest('.form-group').style.display = 'none';
  document.getElementById('modal-member-extra').innerHTML = html;
  document.getElementById('modal-member-confirm').style.display = 'none';
  openModal('modal-member');
}

async function toggleMemberRole(userId, roleId, add) {
  const action = add ? 'add' : 'remove';
  const r = await apiPost(`/members/${userId}/roles/${action}`, { roleId });
  if (r.success) toast(add ? 'Rôle ajouté' : 'Rôle retiré', 'success');
  else toast(r.error, 'error');
}

// ══════════════════════════════════════════════
//  BANS
// ══════════════════════════════════════════════
async function loadBans() {
  state.bans = await api('/bans');
  const el = document.getElementById('bans-list');
  if (!state.bans.length) { el.innerHTML = '<div class="empty"><div class="empty-icon">🚫</div><div class="empty-text">Aucun membre banni</div></div>'; return; }
  el.innerHTML = `<div class="table-wrap"><table><thead><tr><th>Utilisateur</th><th>Raison</th><th>Actions</th></tr></thead><tbody>` +
    state.bans.map(b => `<tr>
      <td><div class="member-cell">
        <div class="member-av"><img src="${b.avatar}" onerror="this.parentElement.textContent='${b.username[0]?.toUpperCase()}'"></div>
        <div><div>${b.username}</div><div style="font-size:10px;color:var(--muted)">${b.userId}</div></div>
      </div></td>
      <td style="color:var(--muted)">${b.reason || 'Aucune raison'}</td>
      <td><button class="btn btn-success btn-sm" onclick="unban('${b.userId}','${b.username.replace(/'/g,"\\'")}')">Débannir</button></td>
    </tr>`).join('') + '</tbody></table></div>';
}

async function unban(userId, name) {
  if (!confirm(`Débannir ${name} ?`)) return;
  const r = await apiPost(`/bans/${userId}/unban`, {});
  if (r.success) { toast(`${name} a été débanni`, 'success'); loadBans(); }
  else toast(r.error, 'error');
}

// ══════════════════════════════════════════════
//  SETTINGS
// ══════════════════════════════════════════════
function populateChannelSelect(id, type, extraOption = true) {
  const el = document.getElementById(id);
  if (!el) return;
  const channels = state.channels.filter(c => type === 'text' ? c.type === 0 : type === 'category' ? c.type === 4 : true);
  el.innerHTML = (extraOption ? '<option value="">Désactivé</option>' : '') + channels.map(c => `<option value="${c.id}">${c.type===4?'📁':c.type===2?'🔊':'#'} ${c.name}</option>`).join('');
  const curVal = state.settings[id.replace('s-','').replace('logs-','')];
  if (curVal) el.value = curVal;
}

function populateRoleSelect(id, extraOption = true) {
  const el = document.getElementById(id);
  if (!el) return;
  el.innerHTML = (extraOption ? '<option value="">Aucun</option>' : '') + state.roles.map(r => `<option value="${r.id}">${r.name}</option>`).join('');
  const curVal = state.settings[id.replace('s-','')];
  if (curVal) el.value = curVal;
}

async function loadSettingsPage() {
  if (!state.settings.guild_id) state.settings = await api('/settings');
  const s = state.settings;
  // Text channels
  ['s-log_channel','s-suggestion_channel','s-report_channel','s-welcome_channel','s-leave_channel','s-levels_channel'].forEach(id => populateChannelSelect(id, 'text'));
  ['s-ticket_category'].forEach(id => populateChannelSelect(id, 'category'));
  // Roles
  ['s-auto_role','s-ticket_support_role'].forEach(id => populateRoleSelect(id));
  // Text inputs
  if (document.getElementById('s-prefix')) document.getElementById('s-prefix').value = s.prefix || '!';
  if (document.getElementById('s-welcome_message')) document.getElementById('s-welcome_message').value = s.welcome_message || '';
  if (document.getElementById('s-leave_message')) document.getElementById('s-leave_message').value = s.leave_message || '';
  if (document.getElementById('s-levels_message')) document.getElementById('s-levels_message').value = s.levels_message || '';
  // Toggles
  if (document.getElementById('s-levels_enabled')) document.getElementById('s-levels_enabled').checked = !!s.levels_enabled;
  if (document.getElementById('s-economy_enabled')) document.getElementById('s-economy_enabled').checked = !!s.economy_enabled;
}

async function saveSettings() {
  const fields = ['prefix','log_channel','suggestion_channel','report_channel','welcome_channel','welcome_message',
    'leave_channel','leave_message','auto_role','levels_enabled','levels_channel','levels_message',
    'economy_enabled','ticket_category','ticket_support_role'];
  const body = {};
  fields.forEach(f => {
    const el = document.getElementById('s-' + f) || document.getElementById('logs-' + f);
    if (!el) return;
    if (el.type === 'checkbox') body[f] = el.checked ? 1 : 0;
    else body[f] = el.value;
  });
  const r = await apiPatch('/settings', body);
  if (r.success) { state.settings = r.settings; toast('Sauvegardé ✅', 'success'); }
  else toast(r.error || 'Erreur', 'error');
}

async function autoSave(key, val) {
  const r = await apiPatch('/settings', { [key]: val });
  if (r.success) { state.settings = r.settings; toast('Sauvegardé', 'success'); }
}

// ══════════════════════════════════════════════
//  MODERATION
// ══════════════════════════════════════════════
async function loadModeration() {
  const [warns, sanctions] = await Promise.all([api('/warnings'), api('/sanctions')]);
  state.warns = warns; state.sanctions = sanctions;
  renderWarns(warns);
  renderSanctions(sanctions);
}

function filterWarnings() {
  const q = document.getElementById('warnSearch').value.toLowerCase();
  renderWarns(state.warns.filter(w => w.user_id.toLowerCase().includes(q) || (w.reason||'').toLowerCase().includes(q)));
}

function renderWarns(warns) {
  const tb = document.getElementById('warns-tbody');
  if (!warns.length) { tb.innerHTML = '<tr><td colspan="5"><div class="empty"><div class="empty-icon">✅</div><div class="empty-text">Aucun avertissement</div></div></td></tr>'; return; }
  tb.innerHTML = warns.map(w => `<tr>
    <td><code style="color:var(--purple-l);font-size:11px">${w.user_id}</code></td>
    <td>${w.reason || '—'}</td>
    <td><code style="font-size:11px;color:var(--muted)">${w.moderator_id}</code></td>
    <td style="color:var(--muted);font-size:12px">${fmtDate(w.created_at)}</td>
    <td><button class="btn btn-danger btn-sm" onclick="deleteWarn(${w.id})">Retirer</button></td>
  </tr>`).join('');
}

function renderSanctions(sanctions) {
  const tb = document.getElementById('sanctions-tbody');
  const typeColors = { ban:'badge-red', kick:'badge-yellow', mute:'badge-blue', warn:'badge-member', timeout:'badge-yellow' };
  if (!sanctions.length) { tb.innerHTML = '<tr><td colspan="4"><div class="empty"><div class="empty-icon">✅</div><div class="empty-text">Aucune sanction</div></div></td></tr>'; return; }
  tb.innerHTML = sanctions.map(s => `<tr>
    <td><span class="badge ${typeColors[s.type]||'badge-member'}">${s.type?.toUpperCase()||'—'}</span></td>
    <td><code style="font-size:11px;color:var(--purple-l)">${s.user_id}</code></td>
    <td>${s.reason || '—'}</td>
    <td style="color:var(--muted);font-size:12px">${fmtDate(s.created_at)}</td>
  </tr>`).join('');
}

function openWarnModal() {
  if (!state.members.length) { toast('Charge les membres d\'abord', 'error'); return; }
  openModal('modal-warn');
}

async function submitWarn() {
  const userId = document.getElementById('warn-user-select').value;
  const reason = document.getElementById('warn-reason').value;
  if (!userId) { toast('Sélectionne un membre', 'error'); return; }
  const r = await apiPost('/warnings', { userId, reason });
  if (r.success) { toast('Warn ajouté ✅', 'success'); closeModal('modal-warn'); loadModeration(); }
  else toast(r.error, 'error');
}

async function deleteWarn(id) {
  if (!confirm('Supprimer cet avertissement ?')) return;
  const r = await apiSupprimer(`/warnings/${id}`);
  if (r.success) { toast('Warn retiré', 'success'); loadModeration(); }
}

// ══════════════════════════════════════════════
//  AUTOMOD
// ══════════════════════════════════════════════
async function loadAutomod() {
  if (!state.settings.guild_id) state.settings = await api('/settings');
  const s = state.settings;
  document.getElementById('s-automod_enabled').checked = !!s.automod_enabled;
  document.getElementById('s-automod_anti_spam').checked = !!s.automod_anti_spam;
  document.getElementById('s-automod_anti_link').checked = !!s.automod_anti_link;
  try { const bw = JSON.parse(s.automod_badwords || '[]'); document.getElementById('badwords-input').value = bw.join('\n'); } catch (_) {}
}

async function saveBadwords() {
  const words = document.getElementById('badwords-input').value.split('\n').map(w => w.trim()).filter(Boolean);
  const r = await apiPatch('/settings', { automod_badwords: JSON.stringify(words) });
  if (r.success) toast('Mots bannis sauvegardés ✅', 'success');
  else toast(r.error, 'error');
}

// ══════════════════════════════════════════════
//  TICKETS
// ══════════════════════════════════════════════
async function loadTickets() {
  await loadSettingsPage();
  state.tickets = await api('/tickets');
  const open = state.tickets.filter(t => t.status === 'open');
  const closed = state.tickets.filter(t => t.status !== 'open');
  const statsEl = document.getElementById('ticket-stats');
  if (statsEl) statsEl.innerHTML = `
    <div class="bar-row"><div class="bar-lbl">Ouverts</div><div class="bar-track"><div class="bar-fill" style="width:${state.tickets.length?Math.round(open.length/state.tickets.length*100):0}%"></div></div><div class="bar-val">${open.length}</div></div>
    <div class="bar-row"><div class="bar-lbl">Fermés</div><div class="bar-track"><div class="bar-fill" style="width:${state.tickets.length?Math.round(closed.length/state.tickets.length*100):0}%;background:var(--dim)"></div></div><div class="bar-val">${closed.length}</div></div>
  `;
  const tb = document.getElementById('tickets-tbody');
  if (!tb) return;
  if (!open.length) { tb.innerHTML = '<tr><td colspan="6"><div class="empty"><div class="empty-icon">🎫</div><div class="empty-text">Aucun ticket ouvert</div></div></td></tr>'; return; }
  tb.innerHTML = open.map(t => `<tr>
    <td><span class="badge badge-blue">#${t.id}</span></td>
    <td><code style="font-size:11px;color:var(--purple-l)">${t.user_id}</code></td>
    <td>${t.subject || '—'}</td>
    <td><code style="font-size:11px;color:var(--muted)">${t.channel_id}</code></td>
    <td style="color:var(--muted);font-size:12px">${fmtDate(t.created_at)}</td>
    <td><button class="btn btn-danger btn-sm" onclick="closeTicket(${t.id})">Fermer</button></td>
  </tr>`).join('');
}

async function closeTicket(id) {
  if (!confirm('Fermer et supprimer ce ticket Discord ?')) return;
  const r = await apiPatch(`/tickets/${id}/close`, {});
  if (r.success) { toast('Ticket fermé ✅', 'success'); loadTickets(); }
  else toast(r.error, 'error');
}

// ══════════════════════════════════════════════
//  ROLES
// ══════════════════════════════════════════════
async function loadRoles2() {
  state.roles = await api('/roles');
  renderRoles(state.roles);
}

function filterRoles() {
  const q = document.getElementById('roleSearch').value.toLowerCase();
  renderRoles(state.roles.filter(r => r.name.toLowerCase().includes(q)));
}

function renderRoles(roles) {
  const tb = document.getElementById('roles-tbody');
  if (!roles.length) { tb.innerHTML = '<tr><td colspan="5"><div class="empty"><div class="empty-icon">🎭</div><div class="empty-text">Aucun rôle</div></div></td></tr>'; return; }
  tb.innerHTML = roles.map(r => `<tr>
    <td><span style="display:inline-flex;align-items:center;gap:7px">
      <span style="width:12px;height:12px;border-radius:50%;background:${r.color||'#99aab5'};display:inline-block"></span>
      <strong>${r.name}</strong>
    </span></td>
    <td><code style="font-size:11px;color:var(--muted)">${r.color}</code></td>
    <td>${r.memberCount}</td>
    <td>${r.position}</td>
    <td><button class="btn btn-danger btn-sm" onclick="deleteRole('${r.id}','${r.name.replace(/'/g,"\\'")}')">Supprimer</button></td>
  </tr>`).join('');
}

function openCreateRoleModal() { document.getElementById('role-name').value=''; openModal('modal-role'); }
async function createRole() {
  const name = document.getElementById('role-name').value;
  const color = document.getElementById('role-color').value;
  if (!name) { toast('Nom requis', 'error'); return; }
  const r = await apiPost('/roles', { name, color });
  if (r.success) { toast(`Rôle "${name}" créé ✅`, 'success'); closeModal('modal-role'); loadRoles2(); }
  else toast(r.error, 'error');
}
async function deleteRole(id, name) {
  if (!confirm(`Supprimer le rôle "${name}" ?`)) return;
  const r = await apiSupprimer(`/roles/${id}`);
  if (r.success) { toast('Rôle supprimé', 'success'); loadRoles2(); }
  else toast(r.error, 'error');
}

// ══════════════════════════════════════════════
//  AUTOROLES
// ══════════════════════════════════════════════
async function loadAutoroles() {
  state.autoroles = await api('/autoroles');
  const sel = document.getElementById('autorole-role-select');
  sel.innerHTML = state.roles.map(r => `<option value="${r.id}">${r.name}</option>`).join('');
  renderAutoroles();
}

function renderAutoroles() {
  const el = document.getElementById('autoroles-list');
  if (!state.autoroles.length) { el.innerHTML = '<div class="empty"><div class="empty-icon">🔄</div><div class="empty-text">Aucun autorole configuré</div></div>'; return; }
  el.innerHTML = state.autoroles.map(ar => {
    const role = state.roles.find(r => r.id === ar.role_id);
    return `<div class="activity-item">
      <div class="activity-dot" style="background:${role?.color||'var(--purple)'}"></div>
      <div class="activity-text"><strong>${role?.name||ar.role_id}</strong> — <span style="color:var(--muted)">${ar.type}</span></div>
      <button class="btn btn-danger btn-sm" onclick="removeAutorole('${ar.role_id}')">✕</button>
    </div>`;
  }).join('');
}

async function addAutorole() {
  const roleId = document.getElementById('autorole-role-select').value;
  const type = document.getElementById('autorole-type-select').value;
  if (!roleId) return;
  const r = await apiPost('/autoroles', { roleId, type });
  if (r.success) { toast('Autorole ajouté ✅', 'success'); state.autoroles = await api('/autoroles'); renderAutoroles(); }
  else toast(r.error, 'error');
}

async function removeAutorole(roleId) {
  const r = await apiSupprimer(`/autoroles/${roleId}`);
  if (r.success) { toast('Autorole retiré', 'success'); state.autoroles = await api('/autoroles'); renderAutoroles(); }
}

// ══════════════════════════════════════════════
//  WELCOME
// ══════════════════════════════════════════════
async function loadWelcome() { await loadSettingsPage(); }

// ══════════════════════════════════════════════
//  LOGS
// ══════════════════════════════════════════════
async function loadLogsPage() {
  if (!state.settings.guild_id) state.settings = await api('/settings');
  populateChannelSelect('logs-log_channel', 'text');
  document.getElementById('logs-log_channel').value = state.settings.log_channel || '';
}
async function saveLogChannel() {
  const val = document.getElementById('logs-log_channel').value;
  const r = await apiPatch('/settings', { log_channel: val });
  if (r.success) toast('Salon de logs sauvegardé ✅', 'success');
  else toast(r.error, 'error');
}

// ══════════════════════════════════════════════
//  COMMANDS
// ══════════════════════════════════════════════
async function loadCommands() {
  state.commands = await api('/commands');
  renderCommands(state.commands);
}
function filterCommands() {
  const q = document.getElementById('cmdSearch').value.toLowerCase();
  renderCommands(state.commands.filter(c => c.name.toLowerCase().includes(q) || c.response.toLowerCase().includes(q)));
}
function renderCommands(cmds) {
  const tb = document.getElementById('commands-tbody');
  if (!cmds.length) { tb.innerHTML = '<tr><td colspan="4"><div class="empty"><div class="empty-icon">💬</div><div class="empty-text">Aucune commande personnalisée</div></div></td></tr>'; return; }
  tb.innerHTML = cmds.map(c => `<tr>
    <td><code style="color:var(--purple-l);font-weight:600">${c.name}</code></td>
    <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--muted)">${c.response}</td>
    <td><code style="font-size:11px;color:var(--muted)">${c.created_by}</code></td>
    <td><button class="btn btn-danger btn-sm" onclick="deleteCmd(${c.id},'${c.name.replace(/'/g,"\\'")}')">Supprimer</button></td>
  </tr>`).join('');
}
function openCreateCmdModal() { document.getElementById('cmd-name').value=''; document.getElementById('cmd-response').value=''; openModal('modal-cmd'); }
async function createCmd() {
  const name = document.getElementById('cmd-name').value;
  const response = document.getElementById('cmd-response').value;
  if (!name || !response) { toast('Nom et réponse requis', 'error'); return; }
  const r = await apiPost('/commands', { name, response });
  if (r.success) { toast('Commande créée ✅', 'success'); closeModal('modal-cmd'); loadCommands(); }
  else toast(r.error || 'Erreur (commande existante ?)', 'error');
}
async function deleteCmd(id, name) {
  if (!confirm(`Supprimer la commande "${name}" ?`)) return;
  const r = await apiSupprimer(`/commands/${id}`);
  if (r.success) { toast('Commande supprimée', 'success'); loadCommands(); }
}

// ══════════════════════════════════════════════
//  ECONOMY
// ══════════════════════════════════════════════
async function loadEconomy() {
  state.economy = await api('/economy');
  const tb = document.getElementById('economy-tbody');
  if (!state.economy.length) { tb.innerHTML = '<tr><td colspan="5"><div class="empty"><div class="empty-icon">💰</div><div class="empty-text">Aucune donnée</div></div></td></tr>'; return; }
  tb.innerHTML = state.economy.map((e,i) => {
    const total = (e.balance||0)+(e.bank||0);
    const medals = ['🥇','🥈','🥉'];
    return `<tr>
      <td>${medals[i]||`#${i+1}`}</td>
      <td><code style="font-size:11px;color:var(--purple-l)">${e.user_id}</code></td>
      <td>${(e.balance||0).toLocaleString()} 🪙</td>
      <td>${(e.bank||0).toLocaleString()} 🏦</td>
      <td><strong>${total.toLocaleString()} 🪙</strong></td>
    </tr>`;
  }).join('');
}

// ══════════════════════════════════════════════
//  LEVELS
// ══════════════════════════════════════════════
async function loadLevels() {
  await loadSettingsPage();
  state.levels = await api('/levels');
  const barsEl = document.getElementById('levels-bars');
  const tb = document.getElementById('levels-tbody');
  if (!state.levels.length) {
    barsEl.innerHTML = '<div class="empty"><div class="empty-icon">📊</div><div class="empty-text">Aucune donnée</div></div>';
    tb.innerHTML = '<tr><td colspan="5"><div class="empty"><div class="empty-icon">📈</div><div class="empty-text">Aucune donnée</div></div></td></tr>';
    return;
  }
  const max = state.levels[0]?.xp || 1;
  barsEl.innerHTML = state.levels.slice(0,10).map(r => `
    <div class="bar-row">
      <div class="bar-lbl">Niv. ${r.level}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${Math.round(r.xp/max*100)}%"></div></div>
      <div class="bar-val">${r.xp}</div>
    </div>`).join('');
  const medals = ['🥇','🥈','🥉'];
  tb.innerHTML = state.levels.map((r,i) => `<tr>
    <td>${medals[i]||`#${i+1}`}</td>
    <td><code style="font-size:11px;color:var(--purple-l)">${r.user_id}</code></td>
    <td><span class="badge badge-blue">Niv. ${r.level}</span></td>
    <td>${(r.xp||0).toLocaleString()} XP</td>
    <td>${(r.messages||0).toLocaleString()}</td>
  </tr>`).join('');
}

// ══════════════════════════════════════════════
//  SHOP
// ══════════════════════════════════════════════
async function loadShop() {
  state.shop = await api('/shop');
  const sel = document.getElementById('shop-role');
  sel.innerHTML = '<option value="">Aucun</option>' + state.roles.map(r => `<option value="${r.id}">${r.name}</option>`).join('');
  renderShop(state.shop);
}
function filterShop() {
  const q = document.getElementById('shopSearch').value.toLowerCase();
  renderShop(state.shop.filter(s => s.name.toLowerCase().includes(q)));
}
function renderShop(items) {
  const tb = document.getElementById('shop-tbody');
  if (!items.length) { tb.innerHTML = '<tr><td colspan="5"><div class="empty"><div class="empty-icon">🛍️</div><div class="empty-text">Boutique vide</div></div></td></tr>'; return; }
  tb.innerHTML = items.map(s => {
    const role = state.roles.find(r => r.id === s.role_id);
    return `<tr>
      <td>${s.emoji || '🛍️'} <strong>${s.name}</strong></td>
      <td style="color:var(--muted)">${s.description || '—'}</td>
      <td><span class="badge badge-yellow">${(s.price||0).toLocaleString()} 🪙</span></td>
      <td>${role ? `<span class="role-pill" style="background:${role.color}22;color:${role.color}">${role.name}</span>` : '—'}</td>
      <td><button class="btn btn-danger btn-sm" onclick="deleteShopItem(${s.id})">Supprimer</button></td>
    </tr>`;
  }).join('');
}
function openAddShopModal() { openModal('modal-shop'); }
async function addShopItem() {
  const name = document.getElementById('shop-name').value;
  const price = parseInt(document.getElementById('shop-price').value);
  if (!name || !price) { toast('Nom et prix requis', 'error'); return; }
  const r = await apiPost('/shop', {
    name, price,
    description: document.getElementById('shop-desc').value,
    emoji: document.getElementById('shop-emoji').value,
    roleId: document.getElementById('shop-role').value || null
  });
  if (r.success) { toast('Article ajouté ✅', 'success'); closeModal('modal-shop'); loadShop(); }
  else toast(r.error, 'error');
}
async function deleteShopItem(id) {
  if (!confirm('Supprimer cet article ?')) return;
  const r = await apiSupprimer(`/shop/${id}`);
  if (r.success) { toast('Article supprimé', 'success'); loadShop(); }
}

// ══════════════════════════════════════════════
//  BROADCAST
// ══════════════════════════════════════════════
function loadBroadcastChannels() {
  const sel = document.getElementById('broadcast-channel');
  const textChannels = state.channels.filter(c => c.type === 0);
  sel.innerHTML = textChannels.map(c => `<option value="${c.id}">#${c.name}</option>`).join('');
}
async function sendBroadcast() {
  const channelId = document.getElementById('broadcast-channel').value;
  const type = document.getElementById('broadcast-type').value;
  const content = document.getElementById('broadcast-content').value;
  if (!channelId || !content) { toast('Salon et message requis', 'error'); return; }
  const body = type === 'embed'
    ? { embed: true, title: document.getElementById('broadcast-title').value, content }
    : { content };
  const r = await apiPost(`/channels/${channelId}/send`, body);
  if (r.success) { toast('Message envoyé ✅', 'success'); document.getElementById('broadcast-content').value = ''; }
  else toast(r.error, 'error');
}

// ══════════════════════════════════════════════
//  MODALS
// ══════════════════════════════════════════════
function openModal(id) {
  const el = document.getElementById(id);
  if (!el) return;
  // Reset hidden fields when reopening
  const rField = el.querySelector('.form-group');
  if (rField) rField.style.display = '';
  const btn = el.querySelector('#modal-member-confirm');
  if (btn) btn.style.display = '';
  el.classList.add('open');
}
function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(el => el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); }));

// ══════════════════════════════════════════════
//  TOAST
// ══════════════════════════════════════════════
let toastTimer;
function toast(msg, type = 'success') {
  const el = document.getElementById('toast');
  const icons = { success: '✅', error: '❌', info: 'ℹ️' };
  document.getElementById('toast-icon').textContent = icons[type] || '✅';
  document.getElementById('toast-msg').textContent = msg;
  el.className = `toast show ${type}`;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 3500);
}

// ══════════════════════════════════════════════
//  UTILS
// ══════════════════════════════════════════════
function fmtDate(ts) {
  if (!ts) return '—';
  const d = new Date(typeof ts === 'number' && ts < 1e12 ? ts * 1000 : ts);
  return isNaN(d) ? '—' : d.toLocaleDateString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' });
}

// Load user info from session
fetch('/api/guild/' + GUILD_ID).then(r=>r.json()).then(g=>{
  if (g.name) document.getElementById('sbUserName').textContent = 'Admin';
}).catch(()=>{});

// Get user info displayed in sidebar
fetch('/auth/me').then(r=>r.json()).then(u=>{
  if (u?.username) {
    document.getElementById('sbUserName').textContent = u.username;
    if (u.avatar) document.getElementById('sbUserAv').src = `https://cdn.discordapp.com/avatars/${u.id}/${u.avatar}.png`;
  }
}).catch(()=>{});

// ── Start ──
init();
</script>
<script>
// ══════════════════════════════════════════════
//  TICKET PANELS
// ══════════════════════════════════════════════

async function loadTicketPanels() {
  const panels = await api('/ticket-panels').catch(() => []);
  const sel = document.getElementById('ticket-panel-select');
  if (!sel) return;
  sel.innerHTML = '<option value="">— Sélectionner un panel —</option>' +
    (panels || []).map(p => `<option value="${p.id}">${p.name || 'Panel #' + p.id}</option>`).join('');
  if (panels && panels.length > 0) { sel.value = panels[0].id; loadPanelDetails(); return; }
  document.getElementById('ticket-no-panel') && (document.getElementById('ticket-no-panel').style.display = 'block');
}

async function loadPanelDetails() {
  const id = document.getElementById('ticket-panel-select')?.value;
  const detail  = document.getElementById('ticket-panel-detail');
  const noPanel = document.getElementById('ticket-no-panel');
  if (!id) {
    if (detail)  detail.style.display  = 'none';
    if (noPanel) noPanel.style.display = 'block';
    return;
  }
  const panel = await api(`/ticket-panels/${id}`).catch(() => null);
  if (!panel) { toast('Erreur chargement panel', 'error'); return; }
  if (detail) detail.style.display = "block";
  const bar = document.getElementById("ticket-action-bar");
  if (bar) bar.style.display = "flex";
  if (noPanel) noPanel.style.display = 'none';
  ['embed_title','embed_description','embed_color','button_label','button_style','welcome_message'].forEach(f => {
    const el = document.getElementById('p-' + f);
    if (el) el.value = panel[f] || '';
  });
  updatePanelPreview();
  loadPanelCategories(id);
  // Remplir les selects de rôles et catégories
  const roleEl = document.getElementById('p-support_role_id');
  const catEl  = document.getElementById('p-default_category_id');
  if (roleEl) {
    roleEl.innerHTML = '<option value="">Aucun</option>' + state.roles.map(r => `<option value="${r.id}">${r.name}</option>`).join('');
    if (panel.support_role_id) roleEl.value = panel.support_role_id;
  }
  if (catEl) {
    catEl.innerHTML = '<option value="">Aucune</option>' + state.channels.filter(c => c.type === 4).map(c => `<option value="${c.id}">📁 ${c.name}</option>`).join('');
    if (panel.default_category_id) catEl.value = panel.default_category_id;
  }
}

function updatePanelPreview() {
  const title  = document.getElementById('p-embed_title')?.value  || '🎫 Ouvrir un ticket';
  const desc   = document.getElementById('p-embed_description')?.value || 'Clique sur le bouton pour ouvrir un ticket.';
  const color  = document.getElementById('p-embed_color')?.value  || '#7c3aed';
  const btnLbl = document.getElementById('p-button_label')?.value || '📩 Ouvrir un ticket';
  if (document.getElementById('prev-title')) document.getElementById('prev-title').textContent = title;
  if (document.getElementById('prev-desc'))  document.getElementById('prev-desc').textContent  = desc;
  if (document.getElementById('prev-btn'))   document.getElementById('prev-btn').textContent   = btnLbl;
  const bar = document.querySelector('#panel-preview > div');
  if (bar) bar.style.borderLeftColor = color;
}

async function savePanelConfig() {
  const id = document.getElementById('ticket-panel-select')?.value;
  if (!id) { toast('Aucun panel sélectionné', 'error'); return; }
  const r = await apiPatch(`/ticket-panels/${id}`, {
    name:            document.getElementById('p-name')?.value,
    channel_id:      document.getElementById('p-channel_id')?.value,
    category_id:     document.getElementById('p-category_id')?.value,
    support_role_id: document.getElementById('p-support_role_id')?.value,
  }).catch(() => ({ success: false }));
  r.success ? toast('Config sauvegardée ✅', 'success') : toast(r.error || 'Erreur', 'error');
}

async function savePanelEmbed() {
  const id = document.getElementById('ticket-panel-select')?.value;
  if (!id) { toast('Aucun panel sélectionné', 'error'); return; }
  const r = await apiPatch(`/ticket-panels/${id}`, {
    embed_title:       document.getElementById('p-embed_title')?.value,
    embed_description: document.getElementById('p-embed_description')?.value,
    embed_color:       document.getElementById('p-embed_color')?.value,
    button_label:      document.getElementById('p-button_label')?.value,
    button_style:      document.getElementById('p-button_style')?.value,
    welcome_message:   document.getElementById('p-welcome_message')?.value,
  }).catch(() => ({ success: false }));
  r.success ? toast('Apparence sauvegardée ✅', 'success') : toast(r.error || 'Erreur', 'error');
}

function openCreatePanelModal() {
  let modal = document.getElementById('modal-create-panel');
  if (!modal) {
    modal = document.createElement('div');
    modal.className = 'modal-overlay';
    modal.id = 'modal-create-panel';
    modal.innerHTML = `
      <div class="modal">
        <div class="modal-title">🎫 Nouveau panel<button class="modal-close" onclick="closeModal('modal-create-panel')">✕</button></div>
        <div class="form-group"><label class="form-label">Nom du panel</label><input class="input" id="new-panel-name" type="text" placeholder="ex: Support général"></div>
        <div class="form-group"><label class="form-label">Salon d'envoi</label><select class="input" id="new-panel-channel"></select></div>
        <div class="form-group"><label class="form-label">Catégorie Discord (pour les tickets)</label><select class="input" id="new-panel-category"></select></div>
        <div class="form-group"><label class="form-label">Rôle staff</label><select class="input" id="new-panel-role"></select></div>
        <div class="modal-actions">
          <button class="btn btn-ghost" onclick="closeModal('modal-create-panel')">Annuler</button>
          <button class="btn btn-primary" onclick="createPanel()">Créer</button>
        </div>
      </div>`;
    modal.addEventListener('click', e => { if (e.target === modal) closeModal('modal-create-panel'); });
    document.body.appendChild(modal);
  }
  document.getElementById('new-panel-channel').innerHTML  = state.channels.filter(c=>c.type===0).map(c=>`<option value="${c.id}">#${c.name}</option>`).join('');
  document.getElementById('new-panel-category').innerHTML = state.channels.filter(c=>c.type===4).map(c=>`<option value="${c.id}">📁 ${c.name}</option>`).join('');
  document.getElementById('new-panel-role').innerHTML     = state.roles.map(r=>`<option value="${r.id}">${r.name}</option>`).join('');
  document.getElementById('new-panel-name').value = '';
  openModal('modal-create-panel');
}

async function createPanel() {
  const name       = document.getElementById('new-panel-name')?.value?.trim();
  const channel_id = document.getElementById('new-panel-channel')?.value;
  const category_id= document.getElementById('new-panel-category')?.value;
  const support_role_id = document.getElementById('new-panel-role')?.value;
  if (!name) { toast('Nom requis', 'error'); return; }
  const r = await apiPost('/ticket-panels', { name, channel_id, category_id, support_role_id }).catch(() => ({ success: false }));
  if (r.success || r.id) {
    toast(`Panel "${name}" créé ✅`, 'success');
    closeModal('modal-create-panel');
    await loadTicketPanels();
    const sel = document.getElementById('ticket-panel-select');
    if (sel && r.id) { sel.value = r.id; loadPanelDetails(); }
  } else {
    toast(r.error || 'Erreur création panel', 'error');
  }
}

async function loadPanelCategories(panelId) {
  const el = document.getElementById('categories-list');
  if (!el) return;
  const cats = await api(`/ticket-panels/${panelId}/categories`).catch(() => []);
  if (!cats?.length) {
    el.innerHTML = '<div class="empty"><div class="empty-icon">📂</div><div class="empty-text">Aucune catégorie</div></div>';
    return;
  }
  el.innerHTML = cats.map(c => `
    <div class="activity-item">
      <div class="activity-dot" style="background:var(--purple)"></div>
      <div class="activity-text"><strong>${c.emoji||'📂'} ${c.name}</strong><span style="color:var(--muted);margin-left:8px;font-size:11px">${c.description||''}</span></div>
      <button class="btn btn-danger btn-sm" onclick="deletePanelCategory(${c.id})">✕</button>
    </div>`).join('');
}

function openCreateCategoryModal() {
  const panelId = document.getElementById('ticket-panel-select')?.value;
  if (!panelId) { toast('Sélectionne un panel d\'abord', 'error'); return; }
  let modal = document.getElementById('modal-create-category');
  if (!modal) {
    modal = document.createElement('div');
    modal.className = 'modal-overlay';
    modal.id = 'modal-create-category';
    modal.innerHTML = `
      <div class="modal">
        <div class="modal-title">📂 Nouvelle catégorie<button class="modal-close" onclick="closeModal('modal-create-category')">✕</button></div>
        <div class="form-group"><label class="form-label">Nom</label><input class="input" id="cat-name" type="text" placeholder="ex: Support général"></div>
        <div class="form-group"><label class="form-label">Description</label><input class="input" id="cat-desc" type="text" placeholder="Courte description"></div>
        <div class="form-group"><label class="form-label">Emoji</label><input class="input" id="cat-emoji" type="text" value="🎧" maxlength="4"></div>
        <div class="modal-actions">
          <button class="btn btn-ghost" onclick="closeModal('modal-create-category')">Annuler</button>
          <button class="btn btn-primary" onclick="createPanelCategory()">Ajouter</button>
        </div>
      </div>`;
    modal.addEventListener('click', e => { if (e.target === modal) closeModal('modal-create-category'); });
    document.body.appendChild(modal);
  }
  openModal('modal-create-category');
}

async function createPanelCategory() {
  const panelId = document.getElementById('ticket-panel-select')?.value;
  const name    = document.getElementById('cat-name')?.value?.trim();
  if (!name) { toast('Nom requis', 'error'); return; }
  const r = await apiPost(`/ticket-panels/${panelId}/categories`, {
    name, description: document.getElementById('cat-desc')?.value,
    emoji: document.getElementById('cat-emoji')?.value || '📂'
  }).catch(() => ({ success: false }));
  if (r.success || r.id) { toast('Catégorie ajoutée ✅', 'success'); closeModal('modal-create-category'); loadPanelCategories(panelId); }
  else toast(r.error || 'Erreur', 'error');
}

async function deletePanelCategory(catId) {
  const panelId = document.getElementById('ticket-panel-select')?.value;
  if (!confirm('Supprimer cette catégorie ?')) return;
  const r = await apiSupprimer(`/ticket-panels/${panelId}/categories/${catId}`).catch(() => ({}));
  if (r.success) { toast('Supprimée', 'success'); loadPanelCategories(panelId); }
  else toast(r.error || 'Erreur', 'error');
}

// Hook propre sans récursion — appelé depuis loadPage()
const _ticketPageLoader = loadPage;
window.loadPage = async function(page) {
  await _ticketPageLoader(page);
  if (page === 'tickets') await loadTicketPanels();
};

// ══ TICKET TOOL STYLE FUNCTIONS ══
function openSection(name) {
  const labels = { general:"⚙️ Général", category:"📂 Catégorie", ticket:"🎫 Ticket", moderator:"👮 Modérateur", permissions:"🔒 Permissions", buttons:"🔘 Boutons", messages:"💬 Messages", escalate:"⬆️ Escalade", panel:"📋 Panel", command_style:"⌨️ Command Style", dropdown_style:"📋 Dropdown Style", thread_style:"🧵 Thread Style", forms:"📝 Forms", transcript:"📄 Transcript", logging:"📋 Logging", automation:"🤖 Automation", limits:"⏱️ Limits", claiming:"✋ Claiming", integrations:"🔗 Integrations" };
  const descs = { general:"Configurez le rôle support et les options générales.", category:"Options pour les catégories ouvertes/fermées.", ticket:"Options générales du ticket.", moderator:"Messages du modérateur.", permissions:"Options de permissions.", buttons:"Liste de tous les boutons.", messages:"Liste de tous les messages.", escalate:"Options d'escalade.", panel:"Options du message du panel.", command_style:"Créer des tickets via commandes.", dropdown_style:"Créer des tickets via menu déroulant.", thread_style:"Tickets en threads au lieu de salons.", forms:"Options des formulaires.", transcript:"Sauvegarder les transcripts.", logging:"Logs du serveur.", automation:"Options d'automatisation.", limits:"Limites et planning.", claiming:"Options de claim.", integrations:"Intégrations de bots externes." };
  let modal = document.getElementById("modal-section");
  if (!modal) {
    modal = document.createElement("div");
    modal.className = "modal-overlay";
    modal.id = "modal-section";
    modal.innerHTML = `<div class="modal"><div class="modal-title"><span id="section-title"></span><button class="modal-close" onclick="closeModal('modal-section')">✕</button></div><div id="section-body" style="color:var(--muted);font-size:13px;padding:8px 0"></div><div class="modal-actions"><button class="btn btn-primary" onclick="closeModal('modal-section')">Fermer</button></div></div>`;
    modal.addEventListener("click", e => { if (e.target === modal) closeModal("modal-section"); });
    document.body.appendChild(modal);
  }
  document.getElementById("section-title").textContent = labels[name] || name;
  document.getElementById("section-body").textContent = descs[name] || "Section en cours de développement.";
  openModal("modal-section");
}

function toggleFrequent() {
  const body = document.getElementById("freq-body");
  const arrow = document.getElementById("freq-arrow");
  if (!body) return;
  const hidden = body.style.display === "none";
  body.style.display = hidden ? "" : "none";
  if (arrow) arrow.textContent = hidden ? "▲" : "▼";
}

async function saveFrequentConfigs() {
  const id = document.getElementById("ticket-panel-select")?.value;
  if (!id) { toast("Aucun panel sélectionné", "error"); return; }
  const roleEl = document.getElementById("p-support_role_id");
  const catEl  = document.getElementById("p-default_category_id");
  const body = {};
  if (roleEl?.value) body.support_role_id = roleEl.value;
  if (catEl?.value)  body.default_category_id = catEl.value;
  const r = await apiPatch(`/ticket-panels/${id}`, body).catch(() => ({ success: false }));
  r.success ? toast("Sauvegardé ✅", "success") : toast(r.error || "Erreur", "error");
}

async function clonePanel() {
  const id   = document.getElementById("ticket-panel-select")?.value;
  const name = document.getElementById("ticket-panel-select")?.selectedOptions[0]?.text;
  if (!id) { toast("Aucun panel sélectionné", "error"); return; }
  const r = await apiPost("/ticket-panels", { name: (name || "Panel") + " (copie)" }).catch(() => ({ success: false }));
  if (r.success || r.id) { toast("Panel cloné ✅", "success"); await loadTicketPanels(); }
  else toast(r.error || "Erreur", "error");
}

function openRenommerPanelModal() {
  const id   = document.getElementById("ticket-panel-select")?.value;
  const name = document.getElementById("ticket-panel-select")?.selectedOptions[0]?.text;
  if (!id) { toast("Aucun panel sélectionné", "error"); return; }
  let modal = document.getElementById("modal-rename-panel");
  if (!modal) {
    modal = document.createElement("div");
    modal.className = "modal-overlay";
    modal.id = "modal-rename-panel";
    modal.innerHTML = `<div class="modal"><div class="modal-title">✏️ Renommer le panel<button class="modal-close" onclick="closeModal('modal-rename-panel')">✕</button></div><div class="form-group"><label class="form-label">Nouveau nom</label><input class="input" id="rename-panel-input" type="text"></div><div class="modal-actions"><button class="btn btn-ghost" onclick="closeModal('modal-rename-panel')">Annuler</button><button class="btn btn-primary" onclick="confirmRenommerPanel()">Renommer</button></div></div>`;
    modal.addEventListener("click", e => { if (e.target === modal) closeModal("modal-rename-panel"); });
    document.body.appendChild(modal);
  }
  document.getElementById("rename-panel-input").value = name || "";
  openModal("modal-rename-panel");
}

async function confirmRenommerPanel() {
  const id   = document.getElementById("ticket-panel-select")?.value;
  const name = document.getElementById("rename-panel-input")?.value?.trim();
  if (!name) { toast("Nom requis", "error"); return; }
  const r = await apiPatch(`/ticket-panels/${id}`, { name }).catch(() => ({ success: false }));
  if (r.success) { toast("Renommé ✅", "success"); closeModal("modal-rename-panel"); await loadTicketPanels(); const sel = document.getElementById("ticket-panel-select"); if (sel) { sel.value = id; } }
  else toast(r.error || "Erreur", "error");
}

async function sendPanel() {
  const id = document.getElementById("ticket-panel-select")?.value;
  if (!id) { toast("Aucun panel sélectionné", "error"); return; }
  const r = await apiPost(`/ticket-panels/${id}/send`, {}).catch(() => ({ success: false }));
  r.success ? toast("Panel envoyé dans le salon ✅", "success") : toast(r.error || "Erreur lors de l'envoi", "error");
}

async function updatePanel() {
  const id = document.getElementById("ticket-panel-select")?.value;
  if (!id) { toast("Aucun panel sélectionné", "error"); return; }
  const r = await apiPost(`/ticket-panels/${id}/send`, { update: true }).catch(() => ({ success: false }));
  r.success ? toast("Panel mis à jour ✅", "success") : toast(r.error || "Erreur", "error");
}

async function setCount() {
  const id = document.getElementById("ticket-panel-select")?.value;
  if (!id) { toast("Aucun panel sélectionné", "error"); return; }
  const count = prompt("Définir le compteur de tickets à :");
  if (count === null || isNaN(parseInt(count))) return;
  const r = await apiPatch(`/ticket-panels/${id}`, { ticket_count: parseInt(count) }).catch(() => ({ success: false }));
  r.success ? toast(`Compteur mis à ${count} ✅`, "success") : toast(r.error || "Erreur", "error");
}

async function deletePanel() {
  const id   = document.getElementById("ticket-panel-select")?.value;
  const name = document.getElementById("ticket-panel-select")?.selectedOptions[0]?.text;
  if (!id) { toast("Aucun panel sélectionné", "error"); return; }
  if (!confirm(`Supprimer le panel "${name}" ? Cette action est irréversible.`)) return;
  const r = await apiSupprimer(`/ticket-panels/${id}`).catch(() => ({ success: false }));
  if (r.success) {
    toast("Panel supprimé", "success");
    document.getElementById("ticket-action-bar").style.display = "none";
    document.getElementById("ticket-panel-detail").style.display = "none";
    document.getElementById("ticket-no-panel").style.display = "block";
    await loadTicketPanels();
  } else toast(r.error || "Erreur", "error");
}

